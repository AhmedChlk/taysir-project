# Copy to .env.production on the VPS and fill real values. NEVER commit .env.production.
# docker-compose.yml reads this file for both the db and web services.

# --- Postgres (consumed by the db service AND must match the URLs below) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=taysir_db

# --- Prisma connection (host "db" = the compose service name) ---
POSTGRES_PRISMA_URL=postgresql://postgres:CHANGE_ME_strong_db_password@db:5432/taysir_db?schema=public
POSTGRES_URL_NON_POOLING=postgresql://postgres:CHANGE_ME_strong_db_password@db:5432/taysir_db?schema=public

# --- NextAuth ---
# NEXTAUTH_SECRET: generate with `openssl rand -base64 48` (min 32 chars).
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
# Public URL the browser reaches. Use the VPS public IP (or domain) + port.
NEXTAUTH_URL=http://YOUR_VPS_PUBLIC_IP:3000
NEXT_PUBLIC_APP_URL=http://YOUR_VPS_PUBLIC_IP:3000

# --- Optional: Vercel Blob (file uploads). Leave empty to use local /uploads volume. ---
BLOB_READ_WRITE_TOKEN=
