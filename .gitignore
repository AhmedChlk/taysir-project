# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
/tests/screenshots/

# Claude Code local settings (may contain secrets)
.claude/settings.json

# AI agent tooling / scratch output
.gemini/
.gemini_security/
.playwright-mcp/
.snyk
GEMINI.md

# Screenshots / scratch captures at repo root (agent working files)
/*.jpeg
/*.jpg
/*.png

# Local binaries / installers
*.deb
