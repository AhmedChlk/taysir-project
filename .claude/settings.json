{
  "mcpServers": {
    "nextjs": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "biome": {
      "command": "npx",
      "args": ["-y", "@biomejs/biome", "lsp-proxy"]
    },
    "snyk-mcp": {
      "command": "npx",
      "args": ["-y", "snyk@latest", "mcp", "-t", "stdio"],
      "env": {
        "SNYK_TOKEN": "TON_TOKEN_ICI"
      }
    }
  }
}