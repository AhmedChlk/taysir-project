generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Etablissement {
  id              String             @id @default(uuid())
  name            String
  slug            String             @unique
  logoUrl         String?
  address         String?
  primaryColor    String?            @default("#0F515C")
  isActive        Boolean            @default(true)
  contractEndDate DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  activities      Activity[]
  attendance      AttendanceRecord[]
  documents       Document[]
  groups          Groupe[]
  messages        Message[]
  paiements       Paiement[]
  paymentPlans    PaymentPlan[]
  rooms           Room[]
  sessions        Session[]
  students        Student[]
  tranches        Tranche[]
  users           User[]
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  firstName        String
  lastName         String
  role             RoleUser
  avatarUrl        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  etablissementId  String?
  salary           Float?
  status           UserStatus     @default(ACTIVE)
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]      @relation("SentMessages")
  sessions         Session[]      @relation("InstructorSessions")
  etablissement    Etablissement? @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  @@unique([id, etablissementId])
  @@index([etablissementId])
}

model Room {
  id              String        @id @default(uuid())
  name            String
  capacity        Int
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  sessions        Session[]

  @@unique([id, etablissementId])
  @@index([etablissementId])
}

model Activity {
  id              String        @id @default(uuid())
  name            String
  description     String?
  duration        Int?
  color           String?       @default("#0F515C")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  sessions        Session[]
  paymentPlans    PaymentPlan[]

  @@unique([id, etablissementId])
  @@index([etablissementId])
}

model Groupe {
  id              String        @id @default(uuid())
  name            String
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  sessions        Session[]
  students        Student[]     @relation("GroupeToStudent")

  @@unique([id, etablissementId])
  @@index([etablissementId])
}

model Student {
  id               String             @id @default(uuid())
  firstName        String
  lastName         String
  email            String?
  phone            String?
  address          String?
  birthDate        DateTime?
  registrationDate DateTime           @default(now())
  isActive         Boolean            @default(true)
  isMinor          Boolean            @default(false)
  parentName       String?
  parentPhone      String?
  parentEmail      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  etablissementId  String
  photoUrl         String?
  attendance       AttendanceRecord[]
  documents        Document[]
  paymentPlans     PaymentPlan[]
  etablissement    Etablissement      @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  groups           Groupe[]           @relation("GroupeToStudent")

  @@unique([id, etablissementId])
  @@index([etablissementId])
}

/// *
///  * PaymentPlan : Le contrat financier global (ex: Frais annuels).
model PaymentPlan {
  id              String            @id @default(uuid())
  totalAmount     Float
  paidAmount      Float             @default(0)
  currency        String            @default("DZD")
  status          StatusPaymentPlan @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  studentId       String
  activityId      String
  etablissementId String
  activity        Activity          @relation(fields: [activityId], references: [id])
  etablissement   Etablissement     @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  student         Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tranches        Tranche[]

  @@unique([id, etablissementId])
  @@index([etablissementId])
  @@index([activityId])
}

/// *
///  * Tranche : Une échéance prévue dans le plan de paiement.
model Tranche {
  id              String        @id @default(uuid())
  amount          Float
  dueDate         DateTime
  isPaid          Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentPlanId   String
  etablissementId String
  paiements       Paiement[]
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  paymentPlan     PaymentPlan   @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)

  @@unique([id, etablissementId])
  @@index([etablissementId])
  @@index([dueDate])
}

/// *
///  * Paiement : Un flux financier réel (reçu).
model Paiement {
  id              String        @id @default(uuid())
  amount          Float
  date            DateTime      @default(now())
  method          PaymentMethod @default(CASH)
  reference       String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  trancheId       String
  etablissementId String
  receiptUrl      String?
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  tranche         Tranche       @relation(fields: [trancheId], references: [id], onDelete: Cascade)

  @@unique([id, etablissementId])
  @@index([etablissementId])
  @@index([date])
}

model Session {
  id              String             @id @default(uuid())
  startTime       DateTime
  endTime         DateTime
  status          StatusSession      @default(SCHEDULED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  activityId      String
  roomId          String
  instructorId    String
  groupId         String
  etablissementId String
  attendance      AttendanceRecord[]
  activity        Activity           @relation(fields: [activityId], references: [id])
  etablissement   Etablissement      @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  group           Groupe             @relation(fields: [groupId], references: [id])
  instructor      User               @relation("InstructorSessions", fields: [instructorId], references: [id])
  room            Room               @relation(fields: [roomId], references: [id])

  @@unique([id, etablissementId])
  @@index([etablissementId])
  @@index([startTime])
}

model AttendanceRecord {
  id              String         @id @default(uuid())
  status          StatutPresence @default(PRESENT)
  retardMinutes   Int?           @default(0)
  note            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  sessionId       String
  studentId       String
  etablissementId String
  etablissement   Etablissement  @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  session         Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([id, etablissementId])
  @@unique([sessionId, studentId, etablissementId])
  @@index([etablissementId])
}

model Document {
  id              String         @id @default(uuid())
  name            String
  url             String
  type            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  etablissementId String
  status          StatusDocument @default(PENDING)
  studentId       String
  etablissement   Etablissement  @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([id, etablissementId])
  @@index([etablissementId])
  @@index([studentId])
}

model Message {
  id              String        @id @default(uuid())
  content         String
  createdAt       DateTime      @default(now())
  senderId        String
  recipientId     String?
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  recipient       User?         @relation("ReceivedMessages", fields: [recipientId], references: [id])
  sender          User          @relation("SentMessages", fields: [senderId], references: [id])

  @@unique([id, etablissementId])
  @@index([etablissementId])
  @@index([senderId])
  @@index([recipientId])
}

enum RoleUser {
  SUPER_ADMIN
  ADMIN
  GERANT
  SECRETAIRE
  INTERVENANT
  PARTICIPANT
  RESPONSABLE
}

enum UserStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
}

enum StatutPresence {
  PRESENT
  ABSENT
  RETARD
  JUSTIFIE
}

enum StatusSession {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum StatusPaymentPlan {
  PENDING
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum StatusDocument {
  PENDING
  APPROVED
  REJECTED
}
